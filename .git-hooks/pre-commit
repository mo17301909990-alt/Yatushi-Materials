#!/bin/bash
# YTS pre-commit hook — 门禁体系
# 适应期：仅警告不阻塞

echo "=== YTS 门禁检查 ==="

# 获取改动的文件
CHANGED_FILES=$(git diff --cached --name-only)
HAS_ERROR=0

# 1. 后端编译检查（如果有 Java 文件改动）
if echo "$CHANGED_FILES" | grep -q "\.java$" || echo "$CHANGED_FILES" | grep -q "pom\.xml$"; then
    echo "[后端] mvn compile -q ..."
    cd yts_project
    mvn compile -q 2>&1 | tail -3
    if [ ${PIPESTATUS[0]} -ne 0 ]; then
        echo "⚠️  后端编译有错误，建议修复后再提交"
        echo "   可用 git commit --no-verify 跳过"
        HAS_ERROR=1
    else
        echo "[后端] 编译通过 ✅"
    fi
    cd ..
fi

# 2. 前端类型检查（如果有前端文件改动）
if echo "$CHANGED_FILES" | grep -q "^yts_project_vueai/"; then
    echo "[前端] vue-tsc --noEmit ..."
    cd yts_project_vueai
    npx vue-tsc --noEmit 2>&1 | tail -5
    if [ ${PIPESTATUS[0]} -ne 0 ]; then
        echo "⚠️  前端类型检查有错误，建议修复后再提交"
        echo "   可用 git commit --no-verify 跳过"
        HAS_ERROR=1
    else
        echo "[前端] 类型检查通过 ✅"
    fi
    cd ..
fi

# 3. 测试检查（适应期仅警告）
if echo "$CHANGED_FILES" | grep -q "^yts_project_vueai/"; then
    echo "[前端] npm run test:run（仅警告）..."
    cd yts_project_vueai
    npm run test:run 2>&1 | tail -5 | grep -v "^$"
    if [ ${PIPESTATUS[0]} -ne 0 ]; then
        echo "⚠️  前端测试有失败，建议修复"
        HAS_ERROR=1
    fi
    cd ..
fi

if echo "$CHANGED_FILES" | grep -q "yts_project/src" ; then
    echo "[后端] 检测到后端改动但跳过集成测试（需要 Docker 且耗时较长）"
    echo "   建议手动运行: cd yts_project && mvn test -Pwith-tests"
fi

if [ $HAS_ERROR -eq 1 ]; then
    echo "=== 门禁检查完成（有警告）==="
else
    echo "=== 门禁检查全部通过 ✅ ==="
fi
exit 0  # 适应期不阻塞提交
