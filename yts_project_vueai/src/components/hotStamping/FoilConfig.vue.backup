  selectedPriceLevel.value = null;
};

const clearPostProcessingStep = () => {
  selectedPostProcessingStep.value = '';
};

const clearLaminationMaterial = () => {
  selectedLaminationMaterial.value = '';
};

const clearGpNumberOnly = () => {
  gpNumber.value = '';
  error.value = '';
};

// 查询函数 - 静态处理
const searchByCompanyNumber = () => {
  if (!companyNumber.value) {
    error.value = '請輸入公司編號';
    return;
  }
  // 模拟查询逻辑
  console.log('查询公司编号:', companyNumber.value);
};

const searchByGpNumber = () => {
  if (!gpNumber.value) {
