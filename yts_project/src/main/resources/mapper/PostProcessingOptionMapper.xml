<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.it.yts_project.mapper.PostProcessingOptionMapper">

    <!-- 结果映射 -->
    <resultMap id="PostProcessingOptionResultMap" type="com.it.yts_project.model.PostProcessingOption">
        <id property="id" column="id"/>
        <result property="stepName" column="step_name"/>
        <result property="stepCode" column="step_code"/>
        <result property="displayOrder" column="display_order"/>
        <result property="isActive" column="is_active"/>
        <result property="description" column="description"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 查询所有后处理工序选项 -->
    <select id="findAll" resultMap="PostProcessingOptionResultMap">
        SELECT * FROM post_processing_options ORDER BY display_order ASC, id ASC
    </select>

    <!-- 查询激活的后处理工序选项 -->
    <select id="findActive" resultMap="PostProcessingOptionResultMap">
        SELECT * FROM post_processing_options WHERE is_active = true ORDER BY display_order ASC, id ASC
    </select>

    <!-- 根据ID查询 -->
    <select id="findById" resultMap="PostProcessingOptionResultMap">
        SELECT * FROM post_processing_options WHERE id = #{id}
    </select>

    <!-- 根据工序名称查询 -->
    <select id="findByStepName" resultMap="PostProcessingOptionResultMap">
        SELECT * FROM post_processing_options WHERE step_name = #{stepName}
    </select>

    <!-- 根据工序编码查询 -->
    <select id="findByStepCode" resultMap="PostProcessingOptionResultMap">
        SELECT * FROM post_processing_options WHERE step_code = #{stepCode}
    </select>

    <!-- 搜索后处理工序选项 -->
    <select id="search" resultMap="PostProcessingOptionResultMap">
        SELECT * FROM post_processing_options 
        WHERE step_name LIKE CONCAT('%', #{keyword}, '%') 
           OR step_code LIKE CONCAT('%', #{keyword}, '%')
           OR description LIKE CONCAT('%', #{keyword}, '%')
        ORDER BY display_order ASC, id ASC
    </select>

    <!-- 插入后处理工序选项 -->
    <insert id="insert" parameterType="com.it.yts_project.model.PostProcessingOption" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO post_processing_options (step_name, step_code, display_order, is_active, description)
        VALUES (#{stepName}, #{stepCode}, #{displayOrder}, #{isActive}, #{description})
    </insert>

    <!-- 更新后处理工序选项 -->
    <update id="update" parameterType="com.it.yts_project.model.PostProcessingOption">
        UPDATE post_processing_options SET
            step_name = #{stepName},
            step_code = #{stepCode},
            display_order = #{displayOrder},
            is_active = #{isActive},
            description = #{description},
            updated_at = CURRENT_TIMESTAMP
        WHERE id = #{id}
    </update>

    <!-- 删除后处理工序选项 -->
    <delete id="deleteById">
        DELETE FROM post_processing_options WHERE id = #{id}
    </delete>

</mapper>
