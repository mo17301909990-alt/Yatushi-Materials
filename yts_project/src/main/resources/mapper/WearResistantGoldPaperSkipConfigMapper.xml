<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.it.yts_project.mapper.WearResistantGoldPaperSkipConfigMapper">

    <!-- 获取所有需要跳过耐磨映射的烫金纸类型 -->
    <select id="getAllSkipPaperTypes" resultType="string">
        SELECT hot_stamping_paper_type
        FROM wear_resistant_gold_paper_skip_config
        ORDER BY hot_stamping_paper_type
    </select>

    <!-- 删除所有配置 -->
    <delete id="deleteAll">
        DELETE FROM wear_resistant_gold_paper_skip_config
    </delete>

    <!-- 批量插入配置 -->
    <insert id="batchInsert">
        INSERT INTO wear_resistant_gold_paper_skip_config (
            hot_stamping_paper_type,
            created_at,
            updated_at
        )
        VALUES
        <foreach collection="types" item="type" separator=",">
            (#{type}, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP)
        </foreach>
    </insert>

</mapper>



